{
  "consumer": {
    "name": "TerraformProviderKosli"
  },
  "interactions": [
    {
      "description": "a request for a greeting",
      "providerState": "a greeting exists",
      "request": {
        "method": "GET",
        "path": "/hello"
      },
      "response": {
        "body": {
          "greeting": "hello world"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.greeting": {
            "match": "type"
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-go": {
      "version": "2.4.3"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "mockserver": "1.2.16",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "KosliAPI"
  }
}